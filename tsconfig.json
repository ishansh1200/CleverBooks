{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* THIS IS THE KEY FIX */
    "jsx": "react-jsx",

    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    "strict": true,
    "allowArbitraryExtensions": true,
    "baseUrl": "./src"
  },
  "include": ["src"]
}